# Database Credentials
DB_HOST=localhost
DB_PORT=5433  # Set to 5433 if bypassing local Postgres, or 5432 if native is stopped
DB_NAME=insightrecruit
DB_USER=postgres
DB_PASSWORD=your_database_password

# Message Queue
REDIS_HOST=localhost
REDIS_PORT=6379
CANDIDATE_UPLOAD_TOPIC=insightrecruit:candidates:uploaded

# Local file storage
UPLOAD_DIR=uploads/resumes

# Security & External APIs
JWT_SECRET=your_super_secret_jwt_signing_key_change_me_in_prod
LLM_API_KEY=sk-your-openai-or-llama-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2